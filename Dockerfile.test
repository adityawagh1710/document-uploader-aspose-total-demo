# Dockerfile.test — Python test runner image.
#
# Used by `make test`, `make lint`, `make typecheck`, etc. Contains:
#   - Python 3.12 + uv
#   - All [project.dependencies] + [dev] + [e2e] extras from pyproject.toml
#     (pytest, hypothesis, ruff, mypy, testcontainers, python-docx, …)
#   - qpdf binary (for qpdf-dependent unit and property tests)
#
# Does NOT contain:
#   - Aspose.Total C++ (not needed; integration tests use a fake worker)
#   - The C++ worker binary (not needed for in-process tests)
#
# This image runs WITHOUT the Aspose SDK tarball being present, so it can
# build immediately. The full production image (Dockerfile, multi-stage)
# requires the SDK.
#
# Dep source of truth: pyproject.toml. Previously this file hardcoded a
# parallel inline pin list which dependabot couldn't see (bot scans
# pyproject.toml only). Drift bit us at least twice — reportlab 4.2.x
# vs >=4.4 on the 3.11→3.12 alignment was the most recent example.

FROM python:3.12-slim-bookworm

# System deps: qpdf for tests, util-linux for prlimit references in tests,
# build-essential because some Python deps compile native bits.
#
# `apt-get upgrade` picks up the latest Debian Bookworm point-release fixes
# for the base image (gnutls, expat, libxml2, etc.) so ECR scan findings on
# this image stay aligned with Dockerfile + Dockerfile.ui. See
# reference_image_security_scanning.md.
RUN apt-get update \
    && apt-get upgrade -y \
    && apt-get install -y --no-install-recommends \
        qpdf \
        util-linux \
        build-essential \
        ca-certificates \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Install uv (modern, fast Python package manager).
RUN pip install --no-cache-dir uv==0.5.*

WORKDIR /app

# Stub package + README so hatchling can complete the editable-install
# handshake without the real source tree present yet. Hatchling validates
# that pyproject.toml's `readme = "README.md"` resolves to a real file.
# All stubs get overwritten by the real source in the next COPY step;
# the test image never needs the real README content at runtime.
# Effect: preserves the dep-install layer cache across source-only
# changes — only pyproject.toml changes bust this layer.
RUN mkdir -p office_convert \
    && touch office_convert/__init__.py office_convert/py.typed README.md
COPY pyproject.toml ruff.toml /app/

# Install project + dev + e2e extras. Editable mode (-e) so the `.pth`
# file points back at /app/office_convert (which the next COPY fills
# with real code).
RUN uv pip install --system --no-cache -e ".[dev,e2e]"

# Copy real source + tests last; overwrites the stub.
COPY office_convert/ /app/office_convert/
COPY tests/ /app/tests/

# Make office_convert importable in editable mode.
ENV PYTHONPATH=/app

# Sensible defaults; Makefile overrides as needed.
CMD ["pytest", "tests/unit", "tests/property", "tests/integration", "-v"]
