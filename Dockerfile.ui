FROM python:3.12-slim-bookworm

# `apt-get upgrade` patches base-image-inherited packages (gnutls28,
# glibc, systemd, expat, etc.) to the latest Debian Bookworm point
# releases. Without it, the slim base ships with whatever package
# versions were current when the python:3.12-slim-bookworm tag was
# built, even if Debian has since released CVE fixes. Worth the
# ~30s build time + ~50 MB layer growth.
RUN apt-get update \
    && apt-get upgrade -y \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Versions pinned to minor (matches pyproject.toml's `==X.Y.*` convention)
# so security patches land but a surprise minor doesn't slip through.
# Refresh by re-running `pip freeze` inside a running test-ui container
# and bumping the floors here when intentional upgrades happen.
RUN pip install --no-cache-dir \
    streamlit==1.57.* \
    requests==2.34.* \
    plotly==6.7.* \
    pandas==3.0.*

COPY office_convert_ui/ /app/office_convert_ui/
WORKDIR /app

EXPOSE 8501

# --server.maxUploadSize=1024 lets the picker accept files up to 1 GB, matching
# the backend ceiling (OFFICE_CONVERT_MAX_INPUT_BYTES=1 GiB). Streamlit's default
# is 200 MB; without this the UI rejects larger uploads before the API sees them.
CMD ["streamlit", "run", "office_convert_ui/app.py", "--server.address", "0.0.0.0", "--server.port", "8501", "--server.maxUploadSize", "1024", "--browser.gatherUsageStats", "false"]
