# =============================================================================
# Aspose licensing — NEVER let the license enter the Docker build context.
# =============================================================================
# The license is bind-mounted at RUN time, never COPY'd at BUILD time.
# If it landed in the image, anyone who pulled the image would get it.
*.lic
*.LIC
*.Lic
*.lic.bak
*.lic.orig
*.lic.old
*.lic.~*
Aspose.*.lic*
**/Aspose.*.lic*

# =============================================================================
# Aspose source bundles — keep parent zips OUT of the Docker build context.
# =============================================================================
# Post-2026-05-12 (Path B) the Dockerfile builder stage receives `vendor/aspose/`
# (4 per-product trees), NOT the parent OS-specific Total zips. So the parent
# zips are excluded — they would bloat the build context with ~4 GB of dead
# weight (the Linux Total is 830 MB; the Windows Total is 3.48 GB).
aspose-total-cpp*.tar.gz
aspose-total-cpp*.tgz
aspose-total-cpp*.zip
aspose.total_for_cpp*.zip
aspose.total_for_cpp*.tar.gz
aspose.total_for_cpp*.tgz

# NOTE: `vendor/aspose/` is INTENTIONALLY INCLUDED in the build context. The
# multi-stage Dockerfile builder stage COPYs it to `/opt/aspose/<Product>/`,
# compiles `office-convert-worker` against it, and the runtime stage copies
# only the `.so` subset it needs. Do NOT add `vendor/aspose/` here.

# =============================================================================
# General secrets — same defensive list as .gitignore.
# A leaked secret in an image is harder to fix than one in git history
# because images may already be pushed to a registry.
# =============================================================================
*.pem
*.key
*.pfx
*.p12
*.jks
*.keystore
.aws/
.azure/
.gcp/
credentials
credentials.json
.env
.env.*
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.ppk

# =============================================================================
# Git + AI-DLC docs + repo metadata — not needed inside the image
# =============================================================================
.git/
.gitignore
.gitattributes
aidlc-docs/

# =============================================================================
# Python build / cache / test artifacts (host-side; image installs fresh)
# =============================================================================
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
*.egg-info/
dist/
build/

# =============================================================================
# C++ host build artifacts (the image's builder stage compiles fresh)
# =============================================================================
worker_cpp/build/
worker_cpp/CMakeCache.txt
worker_cpp/CMakeFiles/
worker_cpp/cmake_install.cmake
worker_cpp/Makefile
worker_cpp/*.o
worker_cpp/*.obj
worker_cpp/compile_commands.json

# =============================================================================
# Test fixtures — corpus binaries are regenerated by the operator if needed
# =============================================================================
tests/corpus/*.docx
tests/corpus/*.pptx
tests/corpus/*.xlsx
tests/corpus/*.pdf
# (corpus/_generate.py + corpus/README.md ARE included)

# =============================================================================
# Runtime state — bind-mounted at run time, not baked into the image
# =============================================================================
/scratch/
/cache/
office-convert-cache/

# =============================================================================
# IDE / editor artifacts
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
